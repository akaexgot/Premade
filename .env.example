# ============================================================================
# RIOTWATCHER (Alternativa flexible para Riot API)
# ============================================================================
# Registrarse en: https://riotwatcher.readthedocs.io/en/latest/
# O usar https://developer.riotgames.com para key directa
RIOTWATCHER_API_KEY=YOUR_RIOT_API_KEY_HERE
RIOTWATCHER_REGION=euw1  # EU West 1

# ============================================================================
# APP CONFIGURATION
# ============================================================================
ENVIRONMENT=development
LOG_LEVEL=debug
